@page "/"

<div class="swipe-deck">
    <!-- Floating Audio Control Panel -->
    <div class="audio-control-panel glassmorphic">
        <button class="audio-btn play-pause-btn" @onclick="TogglePlay">
            @(IsPlaying ? "⏸" : "▶")
        </button>
        <span class="now-playing-label">Now Playing: @(ActiveTrackNum == 1 ? "Sneeker Mc Snoot" : "Snoot's Last Confession")</span>
        <div class="track-selector">
            <button class="track-btn @(ActiveTrackNum == 1 ? "selected" : "")" @onclick="() => SelectTrack(1)">Track 1</button>
            <button class="track-btn @(ActiveTrackNum == 2 ? "selected" : "")" @onclick="() => SelectTrack(2)">Track 2</button>
        </div>
    </div>

    <div class="card-stack" id="cardStack">
        
        <!-- Card 1: Phoning Home -->
        <div class="swipe-card card-1" id="card1">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">Phoning Home.</h1>
                    <blockquote class="seuss-rhyme">
                        Other apps phone home. Every file, click, and keystroke goes to their servers.
                    </blockquote>
                    <button class="cta-btn" @onclick="NextCard">See the Threat &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card1.png" alt="Phoning Home" />
                </div>
            </div>
        </div>
        
        <!-- Card 2: The Server Threat -->
        <div class="swipe-card card-2" id="card2">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">The Server Threat.</h1>
                    <blockquote class="seuss-rhyme">
                        Online databases are giant targets for hackers. If they get breached, your data is exposed.
                    </blockquote>
                    <button class="cta-btn" @onclick="NextCard">See the Solution &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card2.png" alt="The Server Threat" />
                </div>
            </div>
        </div>
        
        <!-- Card 3: On-Device Processing -->
        <div class="swipe-card card-3" id="card3">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">On-Device Processing.</h1>
                    <blockquote class="seuss-rhyme">
                        ZLA apps run 100% inside your browser using your device's power. They never send your data to a server.
                    </blockquote>
                    <button class="cta-btn" @onclick="NextCard">Test It Out &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card3.png" alt="On-Device Processing" />
                </div>
            </div>
        </div>
        
        <!-- Card 4: Disconnect Proof -->
        <div class="swipe-card card-4" id="card4">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">Disconnect Proof.</h1>
                    <blockquote class="seuss-rhyme">
                        You can turn off your internet completely right now. The tool will still function, because it does not rely on a remote server.
                    </blockquote>
                    
                    <div class="interactive-demo">
                        <div class="demo-row">
                            <input type="number" class="demo-number-input" @bind="Num1" @bind:event="oninput" />
                            <select class="demo-select" @bind="Op">
                                <option value="+">+</option>
                                <option value="-">-</option>
                                <option value="*">&times;</option>
                                <option value="/">/</option>
                            </select>
                            <input type="number" class="demo-number-input" @bind="Num2" @bind:event="oninput" />
                            <span class="calc-equals">=</span>
                            <span class="calc-result">@CalcResult</span>
                        </div>
                        <div class="demo-row" style="margin-top: 15px;">
                            <textarea class="demo-textarea" @bind="TextVal" @bind:event="oninput" placeholder="Type text block here..." rows="3"></textarea>
                        </div>
                        <div class="text-stats">
                            <span>Length: @(TextVal?.Length ?? 0) characters</span>
                        </div>
                    </div>

                    <button class="cta-btn secondary" @onclick="NextCard" style="margin-top: 20px;">Next &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card4.png" alt="Disconnect Proof" style="opacity: 0.8;" />
                </div>
            </div>
        </div>
        
        <!-- Card 5: Zero Custody -->
        <div class="swipe-card card-5" id="card5" style="position: relative;">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">Zero Custody.</h1>
                    <blockquote class="seuss-rhyme">
                        You get your results directly on your screen. Because we don't store your files, we can't lose them. No accounts, no logins.
                    </blockquote>
                    <button class="cta-btn" @onclick='() => TriggerConfetti("card5")'>Finish Job</button>
                    <button class="cta-btn secondary" @onclick="NextCard" style="margin-top: 10px;">Finish &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card5.png" alt="Zero Custody" />
                </div>
            </div>
        </div>
        
        <!-- Card 6: Mission Statement -->
        <div class="swipe-card card-6 mission-card" id="card6">
            <div class="card-inner pure-text">
                <h1 class="card-title">Zero-Liability Architecture&trade;</h1>
                <p class="mission-text">
                    Built by Dondlinger General Contracting.<br/>
                    High-impact business utilities. Zero custody. Zero friction. Zero breach exposure.
                </p>
                <div class="social-links">
                    <a href="https://zla.dondlingergc.com" target="_blank">zla.dondlingergc.com</a>
                    <a href="mailto:info@dondlingergc.com">Contact Us</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="progress-rail">
        <div class="progress-dot @(CurrentCard == 0 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 1 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 2 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 3 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 4 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 5 ? "active" : "")"></div>
    </div>
</div>
