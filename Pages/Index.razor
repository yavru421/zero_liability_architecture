@page "/"
@using System.Runtime.InteropServices.JavaScript
@implements IDisposable

<div class="app-container scene-@activeScene">
    <h1 class="pipeline-title">Operational Absolution: The Zero-Liability Architecture (ZLA) Pipeline</h1>
    
    <div class="stage-card">
        @if (activeScene == 1)
        {
            <div class="card-header">
                <span class="stage-label">Step 1: The Greedy Server</span>
                <h2>The Sneeker-Mc-Snoot</h2>
                <div class="seuss-rhyme">
                    "There once was a Server named Sneeker-Mc-Snoot,<br/>
                    Who gathered up data and kept it as loot.<br/>
                    'Give me your passwords! Give me your files!'<br/>
                    You'd upload and wait across miles and miles."
                </div>
            </div>
            <div class="card-visual visual-fortress">
                <div class="visual-placeholder fortress"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Slow and Frustrating</h3>
                <p>Traditional systems make you wait and make you register, collecting security debt every step of the way.</p>
                <div class="gamification-controls">
                    <button class="slow-upload-btn" @onclick="SimulateUpload" disabled="@isUploading">
                        @(isUploading ? $"Uploading... {uploadProgress}%" : "Try Uploading a File")
                    </button>
                    @if(uploadProgress >= 100)
                    {
                        <button class="btn-next" @onclick="NextScene">See the Danger</button>
                    }
                </div>
            </div>
        }
        else if (activeScene == 2)
        {
            <div class="card-header">
                <span class="stage-label neon-text-red">Step 2: The Sneaky Thief</span>
                <h2 class="neon-text-red siren-alert-text">The Database Danger</h2>
                <div class="seuss-rhyme">
                    "But servers are targets for sneaks in the night,<br/>
                    Who steal all your data and run in a fright.<br/>
                    If there is no database locked in a box,<br/>
                    There is nothing to steal, and no picking of locks!"
                </div>
            </div>
            <div class="card-visual visual-breach">
                <div class="visual-placeholder broken-fortress siren-alert"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>"If there is no database to hack, there is no breach to fear."</h3>
                <p>Zero custody means zero liability. We don't store your assets; we reassemble them locally.</p>
                <div class="gamification-controls">
                    <button class="btn-next danger-btn" @onclick="NextScene">Find the Cure</button>
                </div>
            </div>
        }
        else if (activeScene == 3)
        {
            <div class="card-header">
                <span class="stage-label neon-text-cyan">Step 3: The Magic Machine</span>
                <h2 class="neon-text-cyan">Private and Clean!</h2>
                <div class="seuss-rhyme">
                    "So we built a tool that stays right in your hand,<br/>
                    The quickest and safest tool in the land!<br/>
                    It runs in your browser, it lives on your screen,<br/>
                    The cleanest machine that you ever have seen."
                </div>
            </div>
            <div class="card-visual visual-blueprint">
                <div class="visual-placeholder blueprint wireframe-pulse"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Runs on Your Device</h3>
                <p>A Zero-Liability tool processes everything right in front of you—bringing utility without security debt.</p>
                <div class="gamification-controls">
                    <button class="btn-next cyan-btn" @onclick="NextScene">Try the Magic</button>
                </div>
            </div>
        }
        else if (activeScene == 4)
        {
            <div class="card-header">
                <span class="stage-label neon-text-green">Step 4: The Magic Trick</span>
                <h2 class="neon-text-green">The Disappearing Act</h2>
                <div class="seuss-rhyme">
                    "You pour in your numbers, they spin and they slide,<br/>
                    They calculate quickly right here inside.<br/>
                    And once you are done and you close up the tab,<br/>
                    Your data dissolves—there is nothing to grab!"
                </div>
            </div>
            <div class="card-visual visual-pour">
                <div class="visual-placeholder data-pour">
                    <p class="pour-status">Current Status: @(pourState == "ZLA" ? "Processing Locally" : pourState == "Complete" ? "Cleaned & Wiped" : "Ready to Process")</p>
                </div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Wiped Instantly</h3>
                <p>Watch it process in memory, and observe it wipe completely clean when finished.</p>
                <div class="gamification-controls row-controls">
                    <button class="action-btn" @onclick='() => SetPourState("ZLA")'>Process Data Locally</button>
                    <button class="action-btn" @onclick='() => SetPourState("Complete")'>Wipe and Reset</button>
                    @if (pourState == "Complete")
                    {
                        <button class="btn-next green-btn" @onclick="NextScene">Get Your Output</button>
                    }
                </div>
            </div>
        }
        else if (activeScene == 5)
        {
            <div class="card-header">
                <span class="stage-label neon-text-green">Step 5: The Clean Slate</span>
                <h2 class="neon-text-green">Second to None!</h2>
                <div class="seuss-rhyme">
                    "Your PDF's ready, your document's done!<br/>
                    No logins, no signups, the victory's won!<br/>
                    It's fast and it's private, beginning to end,<br/>
                    With zero security debts to defend!"
                </div>
            </div>
            <div class="card-visual visual-output">
                <div class="visual-placeholder dashboard-output">
                    @if(celebrateActive)
                    {
                        <h2 class="neon-text-green celebration-text">🎉 Document Generated Safely 🎉</h2>
                    }
                </div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Absolute Privacy</h3>
                <p>Speed, utility, and absolute data privacy without the security debt of traditional web platforms.</p>
                <div class="gamification-controls">
                    <button class="celebration-btn" @onclick="Celebrate">Get Finished File</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeJavaScriptAsync();
        }
    }

    private async Task InitializeJavaScriptAsync()
    {
        try
        {
            await JSHost.ImportAsync("zla-interop", "../js/zla-interop.js");
            PlayNarrator();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JS Init Error: {ex.Message}");
        }
    }
}
