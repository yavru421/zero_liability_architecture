@page "/"

<div class="swipe-deck">
    <!-- Floating Audio Control Panel -->
    <div class="audio-control-panel glassmorphic">
        <button class="audio-btn play-pause-btn" @onclick="TogglePlay">
            @(IsPlaying ? "⏸" : "▶")
        </button>
        <span class="now-playing-label">Now Playing: @(ActiveTrackNum == 1 ? "Sneeker Mc Snoot" : "Snoot's Last Confession")</span>
        <div class="track-selector">
            <button class="track-btn @(ActiveTrackNum == 1 ? "selected" : "")" @onclick="() => SelectTrack(1)">Track 1</button>
            <button class="track-btn @(ActiveTrackNum == 2 ? "selected" : "")" @onclick="() => SelectTrack(2)">Track 2</button>
        </div>
    </div>

    <div class="card-stack" id="cardStack">
        
        <!-- Card 1: The Upload Trap -->
        <div class="swipe-card card-1" id="card1">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">The Upload Trap.</h1>
                    <blockquote class="seuss-rhyme">
                        When you use standard cloud apps, you have to upload your files to their computers. <br/><br/>
                        The moment your file leaves your device, you lose control. You don't know who is looking at it, where it is copied, or where it will end up.
                    </blockquote>
                    <button class="cta-btn" @onclick="NextCard">See the Danger &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card1.png" alt="The Upload Trap" />
                </div>
            </div>
        </div>
        
        <!-- Card 2: The Giant Target -->
        <div class="swipe-card card-2" id="card2">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">The Giant Target.</h1>
                    <blockquote class="seuss-rhyme">
                        Cloud companies store millions of files in giant online databases. <br/><br/>
                        This makes them massive targets for hackers. If their server gets hacked, your private documents get stolen.
                    </blockquote>
                    <div class="glassmorphic-callout">
                        "If a company doesn't store your files, they can't lose them."
                    </div>
                    <button class="cta-btn" @onclick="NextCard">Find the Solution &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card2.png" alt="The Database Danger" />
                </div>
            </div>
        </div>
        
        <!-- Card 3: Running Locally -->
        <div class="swipe-card card-3" id="card3">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">Running Locally.</h1>
                    <blockquote class="seuss-rhyme">
                        Our apps work like a physical calculator. The tool runs directly inside your web browser using your phone or computer's power.<br/><br/>
                        You use the tool, but you never upload your files to our servers. We never see your data.
                    </blockquote>
                    <button class="cta-btn" @onclick="NextCard">Test It Out &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card3.png" alt="The Magic Machine" />
                </div>
            </div>
        </div>
        
        <!-- Card 4: Wiped Clean -->
        <div class="swipe-card card-4" id="card4">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">Wiped Clean.</h1>
                    <blockquote class="seuss-rhyme">
                        Type some text or numbers below to process it directly on your screen. The moment you click wipe, the memory is deleted.
                    </blockquote>
                    
                    <div class="interactive-demo">
                        <input type="text" class="demo-input" placeholder="Type secret numbers here..." @bind="TestInput" disabled="@IsWiped" />
                        <button class="cta-btn" @onclick="HandleWipe" disabled="@IsWiped">Wipe Memory</button>
                    </div>

                    <button class="cta-btn secondary" @onclick="NextCard" style="margin-top: 20px;">Next &rarr;</button>
                </div>
                <div class="card-illustration">
                    <div class="demo-status-box glassmorphic">
                        <div class="status-line">Files Sent to Server: <span class="status-val green">0 bytes</span></div>
                        <div class="status-line">Files Stored Online: <span class="status-val green">0 bytes</span></div>
                        <div class="status-line">Status: 
                            @if (IsWiped)
                            {
                                <span class="status-val green blinking">100% Wiped & Clean</span>
                            }
                            else if (!string.IsNullOrEmpty(TestInput))
                            {
                                <span class="status-val yellow">Processing on Device CPU</span>
                            }
                            else
                            {
                                <span class="status-val text-muted">Ready</span>
                            }
                        </div>
                    </div>
                    <div class="animated-numbers" id="card4-numbers">
                        @if (!IsWiped && !string.IsNullOrEmpty(TestInput))
                        {
                            @foreach(var c in TestInput)
                            {
                                <span>@c</span>
                            }
                        }
                    </div>
                    <img src="images/card4.png" alt="The Disappearing Act" style="opacity: 0.3;" />
                </div>
            </div>
        </div>
        
        <!-- Card 5: Instant Output -->
        <div class="swipe-card card-5" id="card5" style="position: relative;">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">Instant Output.</h1>
                    <blockquote class="seuss-rhyme">
                        Your finished document is generated directly on your screen and saved to your device.<br/><br/>
                        No signups, no accounts to create, and no passwords to remember. Pure utility, with zero privacy risks.
                    </blockquote>
                    <button class="cta-btn" @onclick='() => TriggerConfetti("card5")'>Get Finished File</button>
                    <button class="cta-btn secondary" @onclick="NextCard" style="margin-top: 10px;">Finish &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card5.png" alt="The Clean Slate" />
                </div>
            </div>
        </div>
        
        <!-- Card 6: Mission Statement -->
        <div class="swipe-card card-6 mission-card" id="card6">
            <div class="card-inner pure-text">
                <h1 class="card-title">Zero-Liability Architecture&trade;</h1>
                <p class="mission-text">
                    Built by Dondlinger General Contracting.<br/>
                    High-impact business utilities. Zero custody. Zero friction. Zero breach exposure.
                </p>
                <div class="social-links">
                    <a href="https://zla.dondlingergc.com" target="_blank">zla.dondlingergc.com</a>
                    <a href="mailto:info@dondlingergc.com">Contact Us</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="progress-rail">
        <div class="progress-dot @(CurrentCard == 0 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 1 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 2 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 3 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 4 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 5 ? "active" : "")"></div>
    </div>
</div>
