@page "/"

<div class="swipe-deck">
    <!-- Floating Audio Control Panel -->
    <div class="audio-control-panel glassmorphic">
        <button class="audio-btn play-pause-btn" @onclick="TogglePlay">
            @(IsPlaying ? "⏸" : "▶")
        </button>
        <span class="now-playing-label">Now Playing: @(ActiveTrackNum == 1 ? "Sneeker Mc Snoot" : "Snoot's Last Confession")</span>
        <div class="track-selector">
            <button class="track-btn @(ActiveTrackNum == 1 ? "selected" : "")" @onclick="() => SelectTrack(1)">Track 1</button>
            <button class="track-btn @(ActiveTrackNum == 2 ? "selected" : "")" @onclick="() => SelectTrack(2)">Track 2</button>
        </div>
    </div>

    <div class="card-stack" id="cardStack">
        
        <!-- Card 1: The Upload Trap -->
        <div class="swipe-card card-1" id="card1">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">The Upload Trap.</h1>
                    <blockquote class="seuss-rhyme">
                        When you upload your files to a cloud in the sky,<br/>
                        (Even to Google Drive, you cannot deny),<br/>
                        Your data is shipped to a server out there,<br/>
                        And what happens in-between... does anyone care?
                    </blockquote>
                    <button class="cta-btn" @onclick="NextCard">See the Danger &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card1.png" alt="The Upload Trap" />
                </div>
            </div>
        </div>
        
        <!-- Card 2: The Server Vault -->
        <div class="swipe-card card-2" id="card2">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">The Server Vault.</h1>
                    <blockquote class="seuss-rhyme">
                        Once it is stored in their black box of data,<br/>
                        It's indexed and read, now or sometime later.<br/>
                        If a hacker breaks in and the security locks fail,<br/>
                        Your private files are suddenly up for sale!
                    </blockquote>
                    <div class="glassmorphic-callout">
                        "If there is no database to hack, there is no breach to fear."
                    </div>
                    <button class="cta-btn" @onclick="NextCard">Find the Solution &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card2.png" alt="The Database Danger" />
                </div>
            </div>
        </div>
        
        <!-- Card 3: The Solution -->
        <div class="swipe-card card-3" id="card3">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">Direct Processing.</h1>
                    <blockquote class="seuss-rhyme">
                        ZLA apps are built to run right in your hand,<br/>
                        The safest and cleanest tools in the land!<br/>
                        They run in your browser, on your own device,<br/>
                        Processing locally, clean and precise.
                    </blockquote>
                    <button class="cta-btn" @onclick="NextCard">Test It Out &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card3.png" alt="The Magic Machine" />
                </div>
            </div>
        </div>
        
        <!-- Card 4: No Data Transit -->
        <div class="swipe-card card-4" id="card4">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">No Data Transit.</h1>
                    <blockquote class="seuss-rhyme">
                        Your files stay home on your own CPU,<br/>
                        No servers in-between reading secrets from you.<br/>
                        And once you are done and you close up the tab,<br/>
                        The memory dissolves &mdash; there is nothing to grab!
                    </blockquote>
                    <button class="cta-btn" @onclick="Dissolve">Close Tab</button>
                    <button class="cta-btn secondary" @onclick="NextCard" style="margin-top: 10px;">Next &rarr;</button>
                </div>
                <div class="card-illustration">
                    <div class="animated-numbers" id="card4-numbers">
                        <span>1</span><span>3</span><span>8</span><span>5</span><span>0</span><span>2</span>
                    </div>
                    <img src="images/card4.png" alt="The Disappearing Act" />
                </div>
            </div>
        </div>
        
        <!-- Card 5: The Output -->
        <div class="swipe-card card-5" id="card5" style="position: relative;">
            <div class="card-frame-border"></div>
            <div class="card-inner">
                <div class="card-content">
                    <h1 class="card-title">The Finished File.</h1>
                    <blockquote class="seuss-rhyme">
                        Your document's ready, the victory's won,<br/>
                        Without sending your files, the processing's done!<br/>
                        It's fast and it's private, beginning to end,<br/>
                        With zero security debts to defend!
                    </blockquote>
                    <button class="cta-btn" @onclick='() => TriggerConfetti("card5")'>Get Finished File</button>
                    <button class="cta-btn secondary" @onclick="NextCard" style="margin-top: 10px;">Finish &rarr;</button>
                </div>
                <div class="card-illustration">
                    <img src="images/card5.png" alt="The Clean Slate" />
                </div>
            </div>
        </div>
        
        <!-- Card 6: Mission Statement -->
        <div class="swipe-card card-6 mission-card" id="card6">
            <div class="card-inner pure-text">
                <h1 class="card-title">Zero-Liability Architecture&trade;</h1>
                <p class="mission-text">
                    Built by Dondlinger General Contracting.<br/>
                    High-impact business utilities. Zero custody. Zero friction. Zero breach exposure.
                </p>
                <div class="social-links">
                    <a href="https://zla.dondlingergc.com" target="_blank">zla.dondlingergc.com</a>
                    <a href="mailto:info@dondlingergc.com">Contact Us</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="progress-rail">
        <div class="progress-dot @(CurrentCard == 0 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 1 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 2 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 3 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 4 ? "active" : "")"></div>
        <div class="progress-dot @(CurrentCard == 5 ? "active" : "")"></div>
    </div>
</div>
