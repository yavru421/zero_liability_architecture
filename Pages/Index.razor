@page "/"
@using System.Runtime.InteropServices.JavaScript
@implements IDisposable

<div class="pipeline-wrapper">
    <h1 class="pipeline-title">Operational Absolution: The Zero-Liability Architecture (ZLA) Pipeline</h1>
    <div class="pipeline-container">
        <div class="stage-card stage-1">
            <div class="card-header">
                <span class="stage-label">Stage 1: The Sluggish SaaS Monument</span>
                <h2>The Fortress of Friction</h2>
                <p>Represented as a giant, locked stone fortress symbolizing traditional SaaS, where users are met with sluggish upload buttons and mandatory sign-up friction.</p>
            </div>
            <div class="card-visual visual-fortress">
                <div class="visual-placeholder fortress"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Centralized Liability</h3>
                <p>Traditional systems force the centralization of sensitive data into fragile databases, creating a massive target for bad actors.</p>
            </div>
        </div>

        <div class="stage-card stage-2">
            <div class="card-header">
                <span class="stage-label neon-text-red">Stage 2: The Attack Surface</span>
                <h2 class="neon-text-red">Breach Vulnerability</h2>
                <p>The fortress appears broken, triggered by visual "neon laser red" sirens and cascading security/compliance warnings.</p>
            </div>
            <div class="card-visual visual-breach">
                <div class="visual-placeholder broken-fortress"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>The Security Debt</h3>
                <p>Every byte of customer data held in custody is a liability; if there is a database to hack, there is a breach to fear.</p>
            </div>
        </div>

        <div class="stage-card stage-3">
            <div class="card-header">
                <span class="stage-label neon-text-cyan">Stage 3: The Digital Jig</span>
                <h2 class="neon-text-cyan">The Paradigm Shift</h2>
                <p>A clean, high-contrast cyan and neon-green wireframe blueprint appears, representing the ZLA "Jig".</p>
            </div>
            <div class="card-visual visual-blueprint">
                <div class="visual-placeholder blueprint"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Scaffolding over Syntax</h3>
                <p>This wireframe neon input form is a temporary structure designed to hold the business logic of CX and browser API interop straight.</p>
            </div>
        </div>

        <div class="stage-card stage-4">
            <div class="card-header">
                <span class="stage-label neon-text-green">Stage 4: The Zero Data Custody Wipe</span>
                <h2 class="neon-text-green">The Data Pour & Form Dissolve</h2>
                <p>Users "pour" data into the jig: as the "concrete" (data output) sets, the neon wireframe form physically dissolves or wipes clean.</p>
            </div>
            <div class="card-visual visual-pour">
                <div class="visual-placeholder data-pour"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Total Data Sovereignty</h3>
                <p>Customer inputs and calculations are processed locally in the Blazor WASM environment and destroyed the moment the browser tab is closed.</p>
            </div>
        </div>

        <div class="stage-card stage-5">
            <div class="card-header">
                <span class="stage-label neon-text-green">Stage 5: The Absolute Output</span>
                <h2 class="neon-text-green">Minimalist Absolution</h2>
                <p>A clean, glassmorphic dashboard displays the final "Absolute Output," such as a generated PDF, accompanied by a celebratory "liquid fluid" or confetti effect.</p>
            </div>
            <div class="card-visual visual-output">
                <div class="visual-placeholder dashboard-output"></div>
            </div>
            <div class="card-footer glassmorphic">
                <h3>Zero Friction, Pure Utility</h3>
                <p>The mission is complete: zero authentication attack surface, zero risk of data breaches, and a deterministic result delivered at edge-native speeds.</p>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeJavaScriptAsync();
        }
    }

    private async Task InitializeJavaScriptAsync()
    {
        try
        {
            await JSHost.ImportAsync("zla-interop", "../js/zla-interop.js");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JS Init Error: {ex.Message}");
        }
    }
}
